// =============================================================================
// TBot_SA1 多数据集预训练配置（JSONC 带注释）
// -----------------------------------------------------------------------------
// 启动方式（.json 与 .jsonc 均可）：
//
//   cd /vla/my_tbot
//   export PYTHONPATH=/vla/my_tbot/src:${PYTHONPATH:-}
//
//   accelerate launch --multi_gpu --num_processes=2 \
//     -m lerobot.scripts.lerobot_train \
//     --config_path=/vla/my_tbot/.配置/pretrain_config.jsonc
//
// 启动前请确认：
//   1. pretrain_repo_ids.txt 中每行一个 LeRobot 3.0 数据集根目录（含 meta/info.json）
//   2. external_stats_root 下按 {robot_type}/{action_mode}/stats.json 组织
//      例：aloha → .test/norm_stats/aloha/abs/stats.json
//          franka_panda_robocasa_test → .test/norm_stats/franka_panda_robocasa_test/abs/stats.json
//   3. 各数据集 robot_type 已在 src/lerobot/transforms/constants.py 注册 MASK/FEATURE/IMAGE
//   4. 混训多机体时必须 action_mode=abs（delta 会导致 action 维度不一致）
//   5. 多数据集不要用 external_stats_path（会共用一份 stats）；用 external_stats_root
//   6. dist_loading=true 时 accelerate 的 num_processes 必须 > 1
//
// CLI 仍可覆盖任意字段，例如：
//   --batch_size=8 --steps=1000 --output_dir=outputs/TBot_SA1/debug_pretrain
// =============================================================================

{
    // =========================================================================
    // 一、数据集（多源混合预训练）
    //    与 finetune 单数据集不同：通过 repo_id_file 列出全部数据源，
    //    weight_rules_path 控制各数据源的采样权重。
    // =========================================================================
    "dataset": {
        "type": "TBot_SA1",
        // 占位 repo_id；实际数据列表由 repo_id_file 提供
        "repo_id": "multidata_from_file",
        "repo_id_file": "/vla/my_tbot/.配置/pretrain_repo_ids.txt",
        // 混训 aloha(14维) + franka(12维) 必须用 abs；delta 会报维度错误
        "action_mode": "abs",
        "use_external_stats": true,
        // 按 robot_type 查找：{external_stats_root}/{robot_type}/{action_mode}/stats.json
        "external_stats_root": "/vla/my_tbot/.test/norm_stats",
        "use_imagenet_stats": false,
        "video_backend": "pyav",
        // 多卡时按数据源总帧数均衡分配到各 rank（要求 num_processes > 1）
        "dist_loading": true,
        "weight_rules_path": "/vla/my_tbot/configs/tbot_sa1_pretrain_data_config.yaml",

        "height": 224,
        "width": 224,
        "max_state_dim": 32,
        "max_action_dim": 32,
        "qwen3_vl_processor_path": "/vla/.models/Qwen3-VL-2B-Instruct",

        "image_transforms": {
            "enable": false,
            "preset": null
        }
    },

    "env": null,

    // =========================================================================
    // 二、策略模型（与 pretrain.sh 默认超参对齐）
    // =========================================================================
    "policy": {
        "type": "TBot_SA1",
        "pretrained_path": "/vla/.models/tbot_base",
        "push_to_hub": false,
        "device": null,

        "dtype": "bfloat16",
        "qwen3_vl_variant": "qwen3_vl_28l",
        "action_expert_variant": "qwen3_28l",
        "qwen3_vl_pretrained_path": "/vla/.models/Qwen3-VL-2B-Instruct",

        "n_obs_steps": 1,
        "chunk_size": 50,
        "n_action_steps": 50,
        "max_state_dim": 32,
        "max_action_dim": 32,
        "attention_mask_mode": "default",

        "num_inference_steps": 10,
        "image_resolution": [224, 224],
        "image_delta_indices": [-15, 0, 15],
        "tokenizer_max_length": 48,

        "normalization_mapping": {
            "VISUAL": "IDENTITY",
            "STATE": "IDENTITY",
            "ACTION": "IDENTITY"
        },

        // 开启 gradient checkpointing 可降低 DA3 3D loss 的显存占用
        "gradient_checkpointing": true,
        "freeze_vision_encoder": false,
        "train_expert_only": false,
        "train_vlm_only": false,

        "optimizer_lr": 5e-5,
        "optimizer_betas": [0.9, 0.95],
        "optimizer_eps": 1e-8,
        "optimizer_weight_decay": 0.01,
        "optimizer_grad_clip_norm": 1.0,
        "scheduler_warmup_steps": 2000,
        "scheduler_decay_steps": 300000,
        "scheduler_decay_lr": 1e-5,

        "scale_factor": 8,
        "lambda_gen": 0.01,
        "cosmos_tokenizer_path_or_name": "/vla/.models/Cosmos-Tokenizer-CI8x8",

        "enable_3d_queries": true,
        "num_3d_query_tokens": 432,
        "da3_alignment_mode": "query_decoder",
        "query_layer_indices": [13, 19, 23, 27],
        "da3_variant": "auto",
        "da3_teacher_layers": [11, 15, 19, 23],
        "da3_query_dim": 2048,
        "da3_tokens_per_view": 1296,
        "da3_num_views": 3,
        "lambda_3d": 0.01,
        "da3_model_path_or_name": "/vla/.models/DA3-LARGE-1.1",
        "da3_code_root": "/vla/my_tbot/third_party/Depth-Anything-3",
        "da3_teacher_process_res": 504,
        "da3_layer_weights": [1.0, 1.2, 1.4, 1.6],
        "log_da3_teacher_timing": false
    },

    // =========================================================================
    // 三、训练流水线
    // =========================================================================
    "output_dir": "outputs/TBot_SA1/pretrain_multidata",
    "job_name": "TBot_SA1-multidata-abs-pretrain",
    "resume": false,
    "seed": 42,
    "num_workers": 4,
    "batch_size": 16,
    "gradient_accumulation_steps": 1,
    "steps": 300000,
    "eval_freq": 1000,
    "log_freq": 25,
    "save_checkpoint": true,
    "save_freq": 10000,
    "use_policy_training_preset": true,

    "eval": {
        "n_episodes": 50,
        "batch_size": 50,
        "use_async_envs": false
    },

    "wandb": {
        "enable": true,
        "project": "TBot_SA1",
        "mode": "offline"
    },

    "rename_map": {}
}
