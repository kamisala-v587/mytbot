// RoboTwin 环境 + my_vla PI05 WebSocket server 评测配置
//
// 用法：
//   cd /vla/my_tbot/evaluation/RoboTwin
//   conda activate tbot_sa1
//   python scripts/inference_pi05_server.py /vla/my_tbot/evaluation/RoboTwin/.config/test_pi05_Fvlm_RAE_sft.jsonc
//
// 先启动 server（myvla 环境）：
// cd /vla/my_vla
// conda activate myvla
//   python /vla/my_vla/scripts/serve_pi05_policy.py --host 0.0.0.0 --port 8001 --infer_horizon 50 --ckpt_path /vla/my_vla/policy/checkpoints/2026-06-09/11-45-55_myvla_adjust_bottle/checkpoints/006000/pretrained_model
//
// 相对路径均相对于 evaluation/RoboTwin/

{
    "ws_host": "127.0.0.1",
    "ws_port": 8001,
    "ws_uri": null,

    // task_idx 对应 inference.py 的 TASK_NAMES（0 = adjust_bottle）
    "task_idx": 0,
    "task_config": "demo_randomized",
    "instruction_type": "unseen",
    "seed": 42,
    "test_num": 10, //测试次数

    "infer_horizon": null,
    "action_horizon_size": 20,
    "action_mode": "abs",
    "binarize_gripper": true,
    "robot_type": [6, 1, 6, 1],

    "video_dir": "output/6.11/test_pi05_Fvlm_RAE_sft_6000", //视频存储路径
    "fps": 10,
    "log_level": "WARNING",
    "debug": false
}
